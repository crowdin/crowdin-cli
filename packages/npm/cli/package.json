    "Command-line interface",
    "Synchronization",
    "Translation management"
  ],
  "optionalDependencies": {
    "@crowdin/cli-darwin-arm64": "5.0.0-next.4",
    "@crowdin/cli-darwin-x64": "5.0.0-next.4",
    "@crowdin/cli-linux-x64": "5.0.0-next.4",
    "@crowdin/cli-linux-arm64": "5.0.0-next.4",
    "@crowdin/cli-linux-x64-musl": "5.0.0-next.4",
    "@crowdin/cli-linux-arm64-musl": "5.0.0-next.4",
    "@crowdin/cli-win32-x64": "5.0.0-next.4"
  }
